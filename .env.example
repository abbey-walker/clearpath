PORT=3001
NODE_ENV=development

# --- Data Source API Keys ---
# News API (newsapi.org - free tier: 100 requests/day)
NEWS_API_KEY=your_newsapi_key_here

# OpenSanctions (opensanctions.org - free for non-commercial, paid for SaaS)
OPEN_SANCTIONS_API_KEY=your_opensanctions_key_here

# OpenCorporates (opencorporates.com - free tier available)
OPENCORPORATES_API_KEY=your_opencorporates_key_here

# Etherscan (etherscan.io - free tier: 5 calls/sec)
ETHERSCAN_API_KEY=your_etherscan_key_here

# Blockchair (blockchair.com - free tier available)
BLOCKCHAIR_API_KEY=your_blockchair_key_here

# --- Internal ---
JWT_SECRET=change_this_to_a_long_random_string
DB_PATH=./data/clearpath.db

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# --- Data Refresh ---
SANCTIONS_REFRESH_CRON=0 2 * * *
